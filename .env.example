# =========================================================================
# Bandari MVP — local-only environment. Copy to .env and fill as needed.
# Nothing here is committed (.env is gitignored). No real money moves.
# =========================================================================

NODE_ENV=development

# ---- API ----
API_PORT=4000
# Public HTTPS base URL for inbound webhooks (set to your tunnel URL when
# exercising real sandboxes, e.g. https://<id>.ngrok-free.app). For mock
# mode the local URL is fine.
PUBLIC_BASE_URL=http://localhost:4000

# ---- Datastore (local brew services or docker compose) ----
DATABASE_URL=postgresql://bandari:bandari@localhost:5432/bandari?schema=public
REDIS_URL=redis://localhost:6379

# ---- Adapter mode ----
# mock   -> every external leg is simulated in-process (fully offline, default)
# live   -> use real sandbox credentials below where present; fall back to mock per-adapter if missing
# NOTE: ADAPTER_MODE=live only activates segments whose *_ENABLED flag is true,
#       so you can run M-Pesa live while keeping on-ramp/payout in mock.
ADAPTER_MODE=mock

# ---- M-Pesa Daraja (sandbox) ----
# To exercise the REAL STK push: set ADAPTER_MODE=live + MPESA_ENABLED=true,
# paste the sandbox app keys + Lipa-na-M-Pesa passkey, and point PUBLIC_BASE_URL
# at your `pnpm tunnel` URL so Safaricom can POST the callback. (Sandbox STK uses
# shortcode 174379 with the test passkey from the Daraja portal.)
MPESA_ENABLED=false
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_PATH=/webhooks/mpesa/stk
MPESA_TEST_MSISDN=254708374149

# ---- Circle (testnet, Developer-Controlled Wallets) ----
CIRCLE_ENABLED=false
CIRCLE_BASE_URL=https://api.circle.com
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
CIRCLE_TREASURY_WALLET_ID=
CIRCLE_HK_WALLET_ID=
CIRCLE_BLOCKCHAIN=BASE-SEPOLIA

# ---- Custody backend selector (only used when ADAPTER_MODE=live) ----
# mock   -> deterministic, no chain (default)
# evm    -> real USDC on an EVM testnet via viem (Path B, see stablecoin:test)
# circle -> Circle Developer-Controlled Wallets (Path A)
CUSTODY_PROVIDER=mock

# ---- EVM testnet custody (Base Sepolia) — the stablecoin testbed (Path B) ----
# Generate the two wallet keys with:  pnpm --filter @bandari/api stablecoin:keygen
# Then fund the treasury: Circle USDC faucet (faucet.circle.com) + a Base Sepolia ETH faucet.
EVM_RPC_URL=https://sepolia.base.org
EVM_CHAIN_ID=84532
EVM_CHAIN_NAME=base-sepolia
# Circle-issued testnet USDC on Base Sepolia.
EVM_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
EVM_EXPLORER_BASE=https://sepolia.basescan.org
EVM_TREASURY_PRIVATE_KEY=
EVM_TREASURY_ADDRESS=
EVM_HK_PRIVATE_KEY=
EVM_HK_ADDRESS=
EVM_CONFIRMATIONS=1
EVM_CONFIRM_TIMEOUT_MS=120000
# Amount (in USDC) the testbed moves per run.
STABLECOIN_TEST_USDC=0.05

# ---- On-ramp KES->USDC (Swypt / Kotani sandbox) ----
ONRAMP_ENABLED=false
ONRAMP_PROVIDER=simulated
ONRAMP_BASE_URL=
ONRAMP_API_KEY=

# ---- HK->CNY payout (Yativo-style; simulated in sandbox) ----
CHINA_PAYOUT_ENABLED=false
CHINA_PAYOUT_BASE_URL=
CHINA_PAYOUT_API_KEY=

# ---- KYC (Smile ID sandbox or stub) ----
KYC_ENABLED=false
KYC_PROVIDER=stub
KYC_BASE_URL=
KYC_API_KEY=

# ---- FX ----
# Static fallback rates used in mock mode (1 USD = N units).
FX_USD_KES=129.50
FX_USD_CNY=7.18
# Margin (bps) added to the mid-market all-in price.
FX_MARGIN_BPS=120
# Quote lock window. Default 24h so a locked rate is honored for a full day.
FX_QUOTE_TTL_SECONDS=86400
